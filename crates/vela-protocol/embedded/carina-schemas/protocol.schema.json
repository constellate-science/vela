{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vela-science.org/carina/schemas/protocol.schema.json",
  "title": "Carina Protocol (v0.3)",
  "description": "A reproducible procedure that produces evidence. Names the assay, instrument, or method backing one or more evidence objects.",
  "type": "object",
  "required": ["schema", "id", "title"],
  "properties": {
    "schema": { "type": "string", "const": "carina.protocol.v0.3" },
    "id": { "type": "string", "pattern": "^vprot_[a-zA-Z0-9_]+$" },
    "title": { "type": "string", "minLength": 1 },
    "produces": {
      "type": "array",
      "items": { "type": "string", "pattern": "^ve_[a-zA-Z0-9_]+$" }
    },
    "version": { "type": "string" }
  }
}
